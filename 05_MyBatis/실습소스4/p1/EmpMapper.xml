<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="p1.EmpMapper">

    <resultMap id="empdeptjoinMap" type="EmpDTO">
      <id  property="empno" column="empno"/>
      <result property="ename" column="ename"/>
      <result property="job" column="job"/>
      <result property="mgr" column="mgr"/>
      <result property="hiredate" column="hiredate"/>
      <result property="sal" column="sal"/>
      <result property="comm" column="comm"/>
      <association property="dto" javaType="DeptDTO">
        <id  property="deptno" column="xxx"/>
        <result property="dname" column="yyy"/>
        <result property="loc" column="zzz"/>
      </association>
    </resultMap>
  	
  	<select id="empdeptjoin" resultMap="empdeptjoinMap">
  		select empno,
  		       ename,
  		       job,
  		       mgr,
  		       hiredate,
  		       sal,
  		       comm,
  		       dept.deptno as xxx,
  		       dept.dname as yyy,
  		       dept.loc as zzz
  		from emp join dept on emp.deptno = dept.deptno
  		order by empno desc
  	</select>

  	
</mapper>